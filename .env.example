# Mithila Utkarsh — environment variables
#
# Copy this file to `.env` and fill in real values.
# The `.env` file is gitignored. Never commit real keys.
#
# For Vercel deployment, add these in the Vercel dashboard:
#   Settings → Environment Variables → add each as VITE_SUPABASE_*

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxx
